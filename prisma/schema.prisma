generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Panel {
  id              String   @id @default(cuid())
  name            String
  loginUrl        String
  targetUrl       String
  email           String
  password        String
  elementSelector String
  elementLabel    String   @default("Değer")
  isActive        Boolean  @default(true)
  checkInterval   Int      @default(30) // saniye
  lastValue       String?
  lastCheck       DateTime?
  lastError       String?
  status          String   @default("pending") // pending, active, error, paused
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  values    ValueHistory[]

  @@map("panels")
}

model ValueHistory {
  id        String   @id @default(cuid())
  panelId   String
  panel     Panel    @relation(fields: [panelId], references: [id], onDelete: Cascade)
  oldValue  String?
  newValue  String
  changedAt DateTime @default(now())

  @@map("value_history")
}

model Settings {
  id              String   @id @default("default")
  telegramToken   String?
  telegramChatIds String[] @default([])
  dailyReportTime String   @default("00:00") // TR saati
  dailyReportEnabled Boolean @default(true)
  timezone        String   @default("Europe/Istanbul")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("settings")
}

model NotificationLog {
  id        String   @id @default(cuid())
  panelId   String?
  panelName String?
  type      String   // change, daily_report, error
  message   String
  success   Boolean
  error     String?
  sentAt    DateTime @default(now())

  @@map("notification_logs")
}
